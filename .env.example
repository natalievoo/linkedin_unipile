# Copy to .env and fill in. .env is gitignored -- never commit real values.

# --- Unipile ---
# API key from the Unipile dashboard. ROTATE the one used during early testing
# before connecting any real account (it was exposed in a chat transcript).
UNIPILE_API_KEY=
# Your Unipile DSN host:port (shown in the dashboard / the sample curl).
UNIPILE_DSN=api43.unipile.com:17362
# The connected LinkedIn account id (from GET /api/v1/accounts).
UNIPILE_ACCOUNT_ID=

# --- Koalake target ---
KOALAKE_CATALOG=linkedin_unipile
KOALAKE_SCHEMA=main
KOALAKE_TABLE=connections

# --- Optional ---
UNIPILE_PAGE_SIZE=100